# LLM Provider: "openai", "anthropic", "openrouter", or "azure_foundry"
LLM_PROVIDER=openrouter

# Model to use
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# OpenRouter API key
OPENROUTER_API_KEY=

# Other provider keys (not needed for openrouter)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_FOUNDRY_ENDPOINT=...
# AZURE_FOUNDRY_API_KEY=...